@model IEnumerable<SiteHairStylist.Models.Inregistrare>

@{
    ViewData["Title"] = "Index";
}

<style>
    .text-white {
        color: #FFFFFF; /* Setează culoarea textului la alb */
    }
</style>

<h1 class="text-white">Index</h1> <!-- Schimbă culoarea textului titlului la alb -->

<p>
    <a asp-action="Create" class="text-white">Create New</a> <!-- Schimbă culoarea textului linkului la alb -->
</p>
<table class="table">
    <thead>
        <tr>
            <th class="text-white">
                @Html.DisplayNameFor(model => model.FirstName)
            </th>
            <th class="text-white">
                @Html.DisplayNameFor(model => model.LastName)
            </th>
            <th class="text-white">
                @Html.DisplayNameFor(model => model.Mobile)
            </th>
            <th class="text-white">
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="text-white">
                    @Html.DisplayFor(modelItem => item.FirstName)
                </td>
                <td class="text-white">
                    @Html.DisplayFor(modelItem => item.LastName)
                </td>
                <td class="text-white">
                    @Html.DisplayFor(modelItem => item.Mobile)
                </td>
                <td class="text-white">
                    @Html.DisplayFor(modelItem => item.Email)
                </td>
                <td class="text-white">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="text-white">Edit</a> | <!-- Schimbă culoarea textului linkului la alb -->
                    <a asp-action="Details" asp-route-id="@item.Id" class="text-white">Details</a> | <!-- Schimbă culoarea textului linkului la alb -->
                    <a asp-action="Delete" asp-route-id="@item.Id" class="text-white">Delete</a> <!-- Schimbă culoarea textului linkului la alb -->
                </td>
            </tr>
        }
    </tbody>
</table>
