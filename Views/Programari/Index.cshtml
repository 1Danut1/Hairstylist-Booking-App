@model IEnumerable<SiteHairStylist.Models.Programari>

@{
    ViewData["Title"] = "Appointments";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <style>
        body {
            background-color: #2c2c2c; /* Dark background */
            color: #FFFFFF; /* White text */
            font-family: 'Oswald', sans-serif;
            margin: 0;
            padding: 0;
        }

        h2 {
            color: #FFD700; /* Gold color */
            font-family: 'Permanent Marker', cursive; /* Graffiti-like font */
            margin-top: 20px;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            margin-top: 20px;
        }

        th, td {
            border: 1px solid #FFFFFF;
            padding: 8px;
            text-align: left;
        }

        th {
            background-color: #FF8C00; /* Dark orange */
        }

        td {
            background-color: #FFA500; /* Orange */
        }

        tr:nth-child(even) {
            background-color: #FFD700; /* Light yellow */
        }

        tr:hover {
            background-color: #FFA500; /* Orange on hover */
        }

        .action-links a {
            color: #FFFFFF; /* White text */
            text-decoration: none;
            margin-right: 5px;
        }

            .action-links a:hover {
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <h2>All Appointments</h2>

    <table>
        <thead>
            <tr>
                <th>Service</th>
                <th>Date and Time</th>
                <th>Status</th>
                <th>User</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Serviciu?.Nume</td>
                    <td>@item.DataOraProgramarii</td>
                    <td>
                        @if (User.IsInRole("Admin"))
                        {
                            <input asp-for="@item.Stare" />
                        }
                        else
                        {
                            @item.Stare
                        }
                    </td>
                    <td>@item.User.UserName</td>
                    <td class="action-links">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.AppointmentID">Edit</a>

                            <a asp-action = "Details" asp-route-id = "@item.AppointmentID" > Details </a> 
                            <a asp-action = "Delete" asp-route-id = "@item.AppointmentID" > Delete </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
